# Python virtual environments — created locally via `make install`
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# macOS noise
.DS_Store

# Editor / IDE
.vscode/
.idea/

# Old template backups (large, point-in-time snapshots)
templates-backup-*/
*.docx.pre-redesign-backup

# Map-image originals — preserved locally by scripts/shrink_map_images.py
# so the shrink is reversible, but the full-res PNGs are 1–7 MB each
# (~14 MB total) and the directions templates only reference the .jpg
# versions. Don't ship them through git.
templates/maps/*-original.png

# Build / temp output
dist/
build/
.eggs/
*.tmp
